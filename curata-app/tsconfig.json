{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "lib": [
      "ESNext",
      "DOM"
    ],
    "module": "preserve",
    "jsx": "react-native",
    "types": [
      "jest",
      "node"
    ],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@domain/*": [
        "./src/domain/*"
      ],
      "@data/*": [
        "./src/data/*"
      ],
      "@presentation/*": [
        "./src/presentation/*"
      ],
      "@infrastructure/*": [
        "./src/infrastructure/*"
      ],
      "@assets/*": [
        "./assets/*"
      ]
    }
  },
  "include": [
    "src",
    "app",
    "*.ts",
    "*.tsx"
  ],
  "extends": "expo/tsconfig.base"
}
